generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// TENANT / AUTH LAYER
// ─────────────────────────────────────────────

model Academy {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  loginKey  String?  @unique // 학생 로그인 ID 접두어 (3글자 대문자 영어, 예: SGR)
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── 토스페이먼츠 (학원별 결제 키) ──────────────────────
  tossClientKey    String? // 공개 키 — 평문 (브라우저 노출 OK)
  tossSecretKeyEnc String? // 비밀 키 — AES-256-GCM 암호화 저장
  tossKeyUpdatedAt DateTime? // 마지막 키 등록/변경 일시
  tossKeyUpdatedBy String? // 변경한 super_admin userId (감사 로그)

  // ── 청구 설정 ────────────────────────────────────────
  siblingDiscountDefault Int    @default(0) // 형제/자매 할인 금액 (type=fixed면 원, percent면 0-100)
  siblingDiscountType    String @default("fixed") // "fixed" | "percent"

  // ── 알림 설정 ────────────────────────────────────────
  smsEnabled Boolean @default(true) // 임시PW SMS 자동 발송 (false=테스트 모드: 폼에서 직접 지정, mustChangePassword 미강제)

  // ── 자동 알림: 결석/지각 (출석 미체크 학생의 학부모에게 PWA 푸시 발송) ──
  attendanceNotifyEnabled  Boolean @default(false) // on/off
  attendanceLateMinutes    Int     @default(10)    // 수업 시작 후 N분 → 지각 알림
  attendanceAbsentMinutes  Int     @default(20)    // 수업 시작 후 M분 → 결석 알림 (반드시 Late < Absent)

  // ── 공개 소개 페이지 (/academy/[slug]) ──────────────────
  intro          String? // 한 줄 소개 (히어로 태그라인, 최대 40자)
  introDetail    String? // 상세 소개 (본문 "학원 소개" 섹션, 줄바꿈 보존)
  directorName   String? // 대표자명
  businessNumber String? // 사업자등록번호
  operatingHours String? // 운영 시간 (자유 입력)
  refundPolicy   String? // 환불 정책
  showFees       Boolean @default(true) // 수강료 공개 여부
  profileEnabled Boolean @default(false) // 공개 페이지 활성화 여부
  kakaoMapUrl    String? // 카카오맵 iframe embed URL
  galleryImages  Json? // string[] — 학원 사진 URL 목록 (최대 6장)

  users                    User[]
  students                 Student[]
  teachers                 Teacher[]
  classes                  Class[]
  bills                    Bill[]
  expenses                 Expense[]
  exams                    Exam[]
  gradeRecords             GradeRecord[]
  attendance               AttendanceRecord[]
  attendanceNotifyLogs     AttendanceNotificationLog[]
  makeupClasses            MakeupClass[]
  calendarEvents           CalendarEvent[]
  classEvents              ClassEvent[]
  notifications            Notification[]
  consultations            ConsultationRecord[]
  announcements            Announcement[]
  textbooks                Textbook[]
  curriculumRows           CurriculumRow[]
  inquiries                PublicInquiry[]
  lectures                 Lecture[]
  lectureSeries            LectureSeries[]
  customTags               AcademyTag[]
  notificationTemplates    NotificationTemplate[]
  lectureQuizzes           LectureQuiz[]
  lectureQuizAttempts      LectureQuizAttempt[]
  lectureRetryPerms        LectureRetryPermission[]
  lectureWatchProgress     LectureWatchProgress[]
  lectureSeriesCompletions LectureSeriesCompletion[]
  certificates             Certificate[]
  examCategories           ExamCategory[]
  assignments              Assignment[]
  reportTemplates          ReportTemplate[]
  reports                  Report[]
  ingangViewSessions       IngangViewSession[]
  ingangDailyCodes         IngangDailyCode[]
  clinicTemplates          ClinicTemplate[]
  lessonComments           LessonComment[]
  clinicResults            ClinicResult[]
  makeupComments           MakeupComment[]
  makeupClinicResults      MakeupClinicResult[]
  enrollmentRules          EnrollmentRule[]
  monthlyAdjustments       MonthlyAdjustment[]
  adjustmentLabels         AdjustmentLabel[]

  @@map("academies")
}

enum UserRole {
  super_admin
  director
  teacher
  parent
  student
  tablet // 인강 시청 전용 태블릿 계정
}

model User {
  id                 String    @id @default(cuid())
  email              String?   @unique // 강사/원장/슈퍼어드민
  loginId            String? // 학생(출석번호), 학부모(전화번호)
  passwordHash       String
  name               String
  role               UserRole
  isActive           Boolean   @default(true)
  tokenVersion       Int       @default(0)
  loginAttempts      Int       @default(0)
  lockedUntil        DateTime?
  mustChangePassword Boolean   @default(false)
  passwordChangedAt  DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // super_admin은 academyId가 null (모든 학원 관리). director/teacher/parent/student는 필수.
  academyId String?
  academy   Academy? @relation(fields: [academyId], references: [id])

  teacherProfile     Teacher?                 @relation("TeacherUser")
  parentProfile      Parent?                  @relation("ParentUser")
  studentProfile     Student?                 @relation("StudentUser")
  retryPermsGiven    LectureRetryPermission[]
  pushSubscriptions  PushSubscription[]
  issuedCertificates Certificate[]            @relation("CertificateIssuedBy")

  @@unique([academyId, loginId])
  @@map("users")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  role      String?
  academyId String?
  action    String
  target    String?
  detail    Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("password_history")
}

// ─────────────────────────────────────────────
// PEOPLE
// ─────────────────────────────────────────────

enum StudentStatus {
  ACTIVE
  ON_LEAVE
  WITHDRAWN
  WAITING
}

model Student {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  name             String
  school           String        @default("")
  grade            Int           @default(1)
  phone            String?
  status           StudentStatus @default(ACTIVE)
  enrollDate       DateTime      @default(now())
  memo             String        @default("")
  avatarColor      String        @default("#4A90D9")
  attendanceNumber String        @default("")
  qrCode           String        @default("")
  birthDate        DateTime?

  userId String? @unique
  user   User?   @relation("StudentUser", fields: [userId], references: [id])

  parentLinks         StudentParent[]
  classEnrollments    ClassEnrollment[]
  siblingLinks        StudentSibling[]          @relation("StudentA")
  siblingOf           StudentSibling[]          @relation("StudentB")
  attendance          AttendanceRecord[]
  gradeRecords        GradeRecord[]
  bills               Bill[]
  makeupTargets       MakeupClassTarget[]
  consultations       ConsultationRecord[]
  quizAttempts        LectureQuizAttempt[]
  retryPerms          LectureRetryPermission[]
  watchProgress       LectureWatchProgress[]
  seriesCompletions   LectureSeriesCompletion[]
  reports             Report[]
  ingangViewSessions  IngangViewSession[]
  lectureTargets      LectureStudentTarget[]
  lessonComments      LessonComment[]
  clinicResults       ClinicResult[]
  makeupComments      MakeupComment[]
  makeupClinicResults MakeupClinicResult[]
  monthlyAdjustments  MonthlyAdjustment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([academyId, attendanceNumber])
  @@map("students")
}

model StudentSibling {
  studentAId String
  studentBId String
  studentA   Student @relation("StudentA", fields: [studentAId], references: [id])
  studentB   Student @relation("StudentB", fields: [studentBId], references: [id])

  @@id([studentAId, studentBId])
  @@map("student_siblings")
}

model Parent {
  id    String @id @default(cuid())
  name  String
  phone String @default("")

  userId String? @unique
  user   User?   @relation("ParentUser", fields: [userId], references: [id])

  children StudentParent[]

  @@map("parents")
}

model StudentParent {
  studentId String
  parentId  String
  student   Student @relation(fields: [studentId], references: [id])
  parent    Parent  @relation(fields: [parentId], references: [id])

  @@id([studentId, parentId])
  @@map("student_parents")
}

model Teacher {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  name        String
  subject     String  @default("")
  phone       String  @default("")
  email       String  @default("")
  avatarColor String  @default("#4A90D9")
  isActive    Boolean @default(true)
  permissions Json    @default("{\"manageStudents\":false,\"manageClasses\":false,\"manageAttendance\":true,\"manageGrades\":true,\"manageFinance\":false,\"manageNotifications\":false,\"viewReports\":true,\"admin\":false}")

  userId String? @unique
  user   User?   @relation("TeacherUser", fields: [userId], references: [id])

  classes           ClassTeacher[]
  checkedAttendance AttendanceRecord[]   @relation("CheckedBy")
  makeupClasses     MakeupClass[]
  consultations     ConsultationRecord[]
  lectures          Lecture[]
  classSchedules    ClassSchedule[]
  classEvents       ClassEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teachers")
}

// ─────────────────────────────────────────────
// CLASSES
// ─────────────────────────────────────────────

model Class {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  name              String
  subject           String  @default("")
  level             String  @default("")
  color             String  @default("#4fc3a1")
  room              String  @default("")
  fee               Int     @default(0)
  feeType           String  @default("monthly") // "monthly" | "weekly" | "per-lesson"
  maxStudents       Int     @default(10)
  description       String  @default("")
  isActive          Boolean @default(true)
  curriculumPalette String  @default("green") // "red" | "orange" | "green" | "custom"

  teachers           ClassTeacher[]
  enrollments        ClassEnrollment[]
  schedules          ClassSchedule[]
  attendance         AttendanceRecord[]
  exams              Exam[]
  bills              Bill[]
  makeupClasses      MakeupClass[]
  textbooks          Textbook[]
  curriculumRows     CurriculumRow[]
  announcements      Announcement[]
  calendarEvents     CalendarEvent[]
  classEvents        ClassEvent[]
  lectureTargets     LectureTarget[]
  assignments        Assignment[]
  reports            Report[]
  lessonComments     LessonComment[]
  clinicResults      ClinicResult[]
  monthlyAdjustments MonthlyAdjustment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("classes")
}

model ClassTeacher {
  classId   String
  teacherId String
  isPrimary Boolean @default(true)
  class     Class   @relation(fields: [classId], references: [id])
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  @@id([classId, teacherId])
  @@map("class_teachers")
}

model ClassEnrollment {
  id         String    @id @default(cuid())
  classId    String
  studentId  String
  enrolledAt DateTime  @default(now())
  droppedAt  DateTime?
  isActive   Boolean   @default(true)
  class      Class     @relation(fields: [classId], references: [id])
  student    Student   @relation(fields: [studentId], references: [id])

  enrollmentRules EnrollmentRule[]

  @@unique([classId, studentId])
  @@map("class_enrollments")
}

model ClassSchedule {
  id        String @id @default(cuid())
  classId   String
  dayOfWeek Int
  startTime String
  endTime   String
  class     Class  @relation(fields: [classId], references: [id])

  // null = 반에 지정된 대표 강사 사용. 값이 있으면 해당 일정 전용 강사.
  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  // 반복 일정의 예외 날짜('YYYY-MM-DD'). "이 날짜만 삭제/수정" 시 해당 날짜를 추가해
  // 캘린더 투영에서 이 회차를 건너뛴다. (수정의 경우 별도 일회성 ClassEvent로 대체)
  skipDates String[] @default([])

  @@map("class_schedules")
}

// ─────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EARLY_LEAVE
}

model AttendanceRecord {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  classId   String
  class     Class   @relation(fields: [classId], references: [id])

  date         DateTime
  status       AttendanceStatus
  checkInTime  String?
  checkOutTime String?
  memo         String           @default("")

  checkedById String?
  checkedBy   Teacher? @relation("CheckedBy", fields: [checkedById], references: [id])
  checkedAt   DateTime @default(now())

  @@unique([studentId, classId, date])
  @@map("attendance_records")
}

model MakeupClass {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  originalClassId String
  originalClass   Class    @relation(fields: [originalClassId], references: [id])
  originalDate    DateTime

  makeupDate DateTime
  makeupTime String   @default("")

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  reason            String  @default("")
  attendanceChecked Boolean @default(false)

  // ── 오픈 보강 슬롯 메타 (Phase 2~3에서 활용, Phase 1엔 default만 들어감) ──
  slotType            MakeupSlotType @default(PERSONAL)
  capacity            Int? // null = 무제한
  applicationDeadline DateTime? // null = 앱에서 makeupDate-1h 계산
  recurrenceGroupId   String? // 반복 슬롯 그룹 식별자
  recurrencePattern   Json? // { daysOfWeek: [1,3], startDate, endDate, time } 등

  targets       MakeupClassTarget[]
  comments      MakeupComment[]
  clinicResults MakeupClinicResult[]

  createdAt DateTime @default(now())

  @@index([academyId, slotType, makeupDate])
  @@index([recurrenceGroupId])
  @@map("makeup_classes")
}

enum MakeupSlotType {
  PERSONAL // 개별 보강 — 기존 흐름 (관리자 주도)
  OPEN // 오픈 보강 — 학부모 PWA 신청
}

enum MakeupApplySource {
  ADMIN // 관리자가 명단에 추가
  PARENT // 학부모 PWA 신청
  SELF // 학생 직접 신청 (Phase 2 이후)
}

model MakeupClassTarget {
  makeupClassId String
  studentId     String
  status        AttendanceStatus?
  memo          String            @default("")

  // ── 신청 출처 추적 (Phase 2~3에서 활용) ──
  appliedBy MakeupApplySource @default(ADMIN)
  appliedAt DateTime          @default(now())

  makeupClass MakeupClass @relation(fields: [makeupClassId], references: [id])
  student     Student     @relation(fields: [studentId], references: [id])

  @@id([makeupClassId, studentId])
  @@map("makeup_class_targets")
}

// 보강 수업에 대한 코멘트 (학생 × 보강 별 1행) — lessons LessonComment와 분리
model MakeupComment {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  makeupClassId String
  makeupClass   MakeupClass @relation(fields: [makeupClassId], references: [id])
  studentId     String
  student       Student     @relation(fields: [studentId], references: [id])

  comment  String
  authorId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([makeupClassId, studentId])
  @@index([academyId])
  @@map("makeup_comments")
}

// 보강 수업의 Clinic 체크 결과 (학생 × 보강 × 양식 별 1행)
model MakeupClinicResult {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  makeupClassId String
  makeupClass   MakeupClass    @relation(fields: [makeupClassId], references: [id])
  studentId     String
  student       Student        @relation(fields: [studentId], references: [id])
  templateId    String
  template      ClinicTemplate @relation(fields: [templateId], references: [id])

  checks        Json
  customItems   Json @default("[]")
  hiddenItemIds Json @default("[]")

  authorId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([makeupClassId, studentId, templateId])
  @@index([academyId])
  @@map("makeup_clinic_results")
}

// ─────────────────────────────────────────────
// GRADES
// ─────────────────────────────────────────────

model Exam {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  name        String
  subject     String   @default("")
  date        DateTime
  totalScore  Int      @default(100)
  // 배점 방식: "SCORE"(만점 기준) | "COUNT"(맞힌 문제 수 기준, score는 100점 환산값)
  scoringMethod  String @default("SCORE")
  totalQuestions Int?   // COUNT 방식일 때 총 문제 수
  description String   @default("")

  // 카테고리 (1은 필수, 2/3은 옵션) — 기존 데이터 호환을 위해 모두 nullable
  category1Id String?
  category1   ExamCategory? @relation("ExamCategory1", fields: [category1Id], references: [id])
  category2Id String?
  category2   ExamCategory? @relation("ExamCategory2", fields: [category2Id], references: [id])
  category3Id String?
  category3   ExamCategory? @relation("ExamCategory3", fields: [category3Id], references: [id])

  gradeRecords GradeRecord[]
  reports      Report[]

  createdAt DateTime @default(now())

  @@map("exams")
}

model ExamCategory {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  name  String
  level Int // 1, 2, 3

  parentId String?
  parent   ExamCategory?  @relation("ExamCategoryHierarchy", fields: [parentId], references: [id])
  children ExamCategory[] @relation("ExamCategoryHierarchy")

  examsAsCategory1 Exam[] @relation("ExamCategory1")
  examsAsCategory2 Exam[] @relation("ExamCategory2")
  examsAsCategory3 Exam[] @relation("ExamCategory3")

  createdAt DateTime @default(now())

  @@index([academyId, level])
  @@index([parentId])
  @@map("exam_categories")
}

model GradeRecord {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  examId    String
  exam      Exam    @relation(fields: [examId], references: [id])
  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  score        Float? // COUNT 방식이면 100점 환산값
  correctCount Int?   // COUNT 방식일 때 맞힌 문제 수
  rank         Int?
  memo         String @default("")

  @@unique([examId, studentId])
  @@map("grade_records")
}

// ─────────────────────────────────────────────
// ASSIGNMENTS
// ─────────────────────────────────────────────

model Assignment {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  date    DateTime // 과제 출제일 (반 시간표 날짜 가능)
  dueDate DateTime // 납기일
  memo    String   @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([academyId, classId])
  @@index([dueDate])
  @@map("assignments")
}

// ─────────────────────────────────────────────
// FINANCE
// ─────────────────────────────────────────────

enum BillStatus {
  DRAFT
  PAID
  UNPAID
  PARTIAL
  CANCELLED
}

enum PaymentMethod {
  CARD
  TRANSFER
  CASH
}

model Bill {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  classId   String
  class     Class   @relation(fields: [classId], references: [id])

  month          String
  amount         Int
  paidAmount     Int            @default(0)
  status         BillStatus     @default(UNPAID)
  dueDate        DateTime
  paidDate       DateTime?
  method         PaymentMethod?
  memo           String         @default("")
  adjustAmount   Int            @default(0) // 청구액 조정 차감 금액 (최근 조정 기준)
  adjustMemo     String         @default("") // 조정 사유 (최근 조정 기준)
  scheduledCount Int? // per-lesson: 해당 월 배정 수업 횟수
  absentCount    Int? // per-lesson: 결석 횟수
  makeupCount    Int? // per-lesson: 보강으로 복원된 횟수
  notifiedAt     DateTime? // 학부모에게 청구서 알림 발송 시각

  cancelledAt    DateTime? // 취소 시각 (CANCELLED 상태 시 기록)
  cancelReason   String? // 취소 사유
  paymentOrderId String? // 결제된 토스 PaymentOrder ID (취소 시 원본 주문 추적)

  // 재청구 링크 — 취소된 청구서에서 새로 생성된 청구서를 추적
  rebillOfId String?
  rebillOf   Bill?   @relation("BillRebill", fields: [rebillOfId], references: [id])
  rebills    Bill[]  @relation("BillRebill")

  receipts    Receipt[]
  adjustments BillAdjustment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, classId, month])
  @@map("bills")
}

// ─── Layer 2: 수강 등록별 반복 조정 (형제할인 등) ───────────────
// ClassEnrollment 1:N, 삭제 시 Cascade
model EnrollmentRule {
  id           String   @id @default(cuid())
  academyId    String
  enrollmentId String // ClassEnrollment.id
  label        String // 예: "형제할인", "교재비"
  direction    String // "add" | "discount"
  amountType   String   @default("fixed") // "fixed" | "percent"
  amount       Int // fixed: 원 단위 / percent: 0-100 정수
  memo         String   @default("")
  isAuto       Boolean  @default(false) // 시스템 자동 생성 (형제 할인 등) — 동기화 대상
  autoTag      String? // "sibling" 등 자동 규칙 구분 태그
  createdAt    DateTime @default(now())

  academy    Academy         @relation(fields: [academyId], references: [id], onDelete: Cascade)
  enrollment ClassEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([academyId, enrollmentId])
  @@index([enrollmentId, autoTag])
  @@map("enrollment_rules")
}

// ─── 월별 조정용 명칭 사전 (교재비, 활동비 등) ─────────────────
model AdjustmentLabel {
  id        String   @id @default(cuid())
  academyId String
  name      String // 예: "교재비", "활동비", "특강비"
  createdAt DateTime @default(now())

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@unique([academyId, name])
  @@map("adjustment_labels")
}

// ─── Layer 3: 월별 1회성 조정 (교재비, 특강비 등) ────────────────
// scope: "class" | "student"
// classId / studentId nullable — 삭제 시 SetNull (조정 이력 보존)
model MonthlyAdjustment {
  id           String   @id @default(cuid())
  academyId    String
  billingMonth String // "YYYY-MM"
  scope        String // "class" | "student"
  classId      String? // scope=class 시 필수
  studentId    String? // scope=student 시 필수
  label        String
  direction    String // "add" | "discount"
  amount       Int // 원 단위 고정금액
  memo         String   @default("")
  createdAt    DateTime @default(now())

  academy Academy  @relation(fields: [academyId], references: [id], onDelete: Cascade)
  class   Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([academyId, billingMonth])
  @@map("monthly_adjustments")
}

// 청구액 조정 이력 — 조정할 때마다 1건 기록 (감사 추적)
model BillAdjustment {
  id     String @id @default(cuid())
  billId String
  bill   Bill   @relation(fields: [billId], references: [id])

  amount        Int // 이 조정으로 설정된 차감 금액
  memo          String @default("") // 조정 사유
  createdByName String @default("") // 조정 처리자 이름

  createdAt DateTime @default(now())

  @@index([billId])
  @@map("bill_adjustments")
}

model Expense {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  category    String
  description String
  amount      Int
  date        DateTime
  memo        String   @default("")

  createdAt DateTime @default(now())

  @@map("expenses")
}

model Receipt {
  id     String @id @default(cuid())
  billId String
  bill   Bill   @relation(fields: [billId], references: [id])

  studentId   String
  amount      Int
  issuedDate  DateTime
  method      PaymentMethod
  memo        String        @default("")
  paidBy      String        @default("") // 수납 처리자 userId (관리자 수동 처리 시 기록, 토스 자동결제 시 빈 문자열)
  cancelledAt DateTime? // 영수증 취소 시각 (청구서 취소 시 함께 기록)

  createdAt DateTime @default(now())

  @@map("receipts")
}

// ─────────────────────────────────────────────
// COMMUNICATIONS
// ─────────────────────────────────────────────

enum NotificationType {
  ANNOUNCEMENT
  ATTENDANCE_ALERT
  PAYMENT_ALERT
  CONSULTATION_ALERT
  GENERAL
}

model Notification {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  type     NotificationType
  title    String
  content  String
  metadata Json? // { billIds: string[] } 등 추가 데이터
  sentAt   DateTime         @default(now())
  sentById String           @default("")

  recipients NotificationRecipient[]

  @@map("notifications")
}

model PaymentOrder {
  id         String   @id @default(cuid())
  academyId  String
  studentId  String
  billIds    Json // string[] — 결제 대상 청구서 ID 목록
  amount     Int
  status     String   @default("PENDING") // PENDING | PROCESSING | PAID | FAILED
  paymentKey String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("payment_orders")
}

model NotificationRecipient {
  notificationId String
  studentId      String
  readAt         DateTime?

  notification Notification @relation(fields: [notificationId], references: [id])

  @@id([notificationId, studentId])
  @@map("notification_recipients")
}

model ConsultationRecord {
  id        String  @id @default(cuid())
  academyId String
  studentId String
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  student   Student @relation(fields: [studentId], references: [id])
  academy   Academy @relation(fields: [academyId], references: [id])

  date     DateTime
  time     String   @default("")
  duration Int      @default(30)
  type     String
  topic    String
  content  String   @default("")
  followUp String   @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("consultation_records")
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
}

model Announcement {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  title       String
  content     String
  authorId    String
  status      AnnouncementStatus @default(DRAFT)
  pinned      Boolean            @default(false)
  publishedAt DateTime?

  classId String?
  class   Class?  @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

// ─────────────────────────────────────────────
// NOTIFICATION TEMPLATE (알림 템플릿)
// ─────────────────────────────────────────────

model NotificationTemplate {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  category NotificationType
  title    String
  content  String

  // 시스템 시드 템플릿 식별용. NULL = 사용자가 만든 자유 템플릿, 'ATTENDANCE_LATE_AUTO' 같은 값 = 시드 템플릿.
  // (academyId, code) UNIQUE → 학원마다 시드 1개 + 자유 템플릿 다수.
  code String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([academyId, code])
  @@map("notification_templates")
}

// 자동 알림 중복 발송 방지 로그. (classId, studentId, date, kind) UNIQUE 로
// cron이 매 5분 재실행돼도 같은 알림이 두 번 가지 않도록 보장.
model AttendanceNotificationLog {
  id        String   @id @default(cuid())
  academyId String
  academy   Academy  @relation(fields: [academyId], references: [id])
  classId   String
  studentId String
  date      DateTime // 자정(00:00) 기준 정규화
  kind      String   // 'LATE' | 'ABSENT'
  sentAt    DateTime @default(now())

  @@unique([classId, studentId, date, kind])
  @@index([academyId, sentAt])
  @@map("attendance_notification_logs")
}

// ─────────────────────────────────────────────
// PUBLIC INQUIRY (공개 페이지 상담 신청)
// ─────────────────────────────────────────────

enum InquiryStatus {
  NEW // 신규 (미확인)
  READ // 확인
  REPLIED // 답변완료
}

model PublicInquiry {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  name      String // 학생 이름
  phone     String // 연락처
  classId   String? // 관심 수업 ID (선택)
  className String? // 관심 수업명 스냅샷
  message   String  @default("") // 문의 내용

  status InquiryStatus @default(NEW)
  memo   String        @default("") // 원장 메모

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("public_inquiries")
}

// ─────────────────────────────────────────────
// CALENDAR
// ─────────────────────────────────────────────

enum CalendarEventType {
  ACADEMY_SCHEDULE
  CONSULTATION_SCHEDULE
  MAKEUP_SCHEDULE
  CLOSED_DAY // 휴원일 — 반복 보강 슬롯 생성 시 자동 제외 대상
}

// ─────────────────────────────────────────────
// CURRICULUM
// ─────────────────────────────────────────────

model Textbook {
  id           String    @id @default(cuid())
  academyId    String
  classId      String
  name         String
  publisher    String    @default("")
  unit         String    @default("권")
  totalUnits   Int       @default(1)
  currentUnit  Int       @default(1)
  price        Int       @default(0)
  isbn         String    @default("")
  purchaseDate DateTime?
  memo         String    @default("")

  academy Academy @relation(fields: [academyId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("textbooks")
}

enum CurriculumUnitType {
  MONTH
  WEEK
  SESSION
}

model CurriculumRow {
  id        String             @id @default(cuid())
  academyId String
  classId   String
  unitType  CurriculumUnitType @default(WEEK)
  startWeek Int                @default(1)
  endWeek   Int                @default(1)
  topic     String
  detail    String             @default("")
  color     String? // 사용자 직접 지정 색 (null이면 팔레트 자동 부여)
  done      Boolean            @default(false)

  academy Academy @relation(fields: [academyId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("curriculum_rows")
}

model CalendarEvent {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  title       String
  date        DateTime
  startTime   String?
  endTime     String?
  type        CalendarEventType
  isPublic    Boolean           @default(true)
  description String            @default("")
  color       String            @default("#4fc3a1")

  classId          String?
  class            Class?  @relation(fields: [classId], references: [id])
  relatedStudentId String?

  createdAt DateTime @default(now())

  @@map("calendar_events")
}

// 반 일회성 수업 일정 — 특정 날짜에 추가되는 단발성 수업 (반복 일정은 ClassSchedule)
model ClassEvent {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  date      DateTime
  startTime String
  endTime   String

  // null = 반에 지정된 대표 강사 사용. 값이 있으면 해당 일정 전용 강사.
  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  createdAt DateTime @default(now())

  @@index([academyId, date])
  @@map("class_events")
}

// ─────────────────────────────────────────────
// IN-GANG (인강)
// ─────────────────────────────────────────────

enum LectureStatus {
  DRAFT
  PUBLISHED
}

enum LectureTargetMode {
  CLASS // 반 단위 지정
  INDIVIDUAL // 개별 학생 지정
  ALL // 전체 공개
}

model Lecture {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  title       String
  description String   @default("")
  teacherId   String?
  teacher     Teacher? @relation(fields: [teacherId], references: [id])

  subjects     String[] @default([])
  levels       String[] @default([])
  targetGrades String[] @default([])
  etcTags      String[] @default([])

  seriesId      String?
  series        LectureSeries? @relation(fields: [seriesId], references: [id])
  episodeNumber Int?

  cfVideoId   String? // Cloudflare Stream video UID
  videoUrl    String?
  duration    String        @default("--:--")
  durationSec Int? // Cloudflare Stream에서 받아온 영상 길이(초). 진도율 계산의 서버 진실 원천.
  orderIndex  Int           @default(0)
  status      LectureStatus @default(DRAFT)

  targetMode LectureTargetMode @default(CLASS)

  targets        LectureTarget[]
  studentTargets LectureStudentTarget[]
  quiz           LectureQuiz?
  watchProgress  LectureWatchProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lectures")
}

model LectureSeries {
  id          String                    @id @default(cuid())
  academyId   String
  academy     Academy                   @relation(fields: [academyId], references: [id])
  title       String
  description String                    @default("")
  orderIndex  Int                       @default(0)
  status      LectureStatus             @default(DRAFT)
  lectures    Lecture[]
  completions LectureSeriesCompletion[]
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@map("lecture_series")
}

model LectureTarget {
  lectureId String
  classId   String
  lecture   Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  class     Class   @relation(fields: [classId], references: [id])

  @@id([lectureId, classId])
  @@map("lecture_targets")
}

model LectureStudentTarget {
  lectureId String
  studentId String
  lecture   Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([lectureId, studentId])
  @@map("lecture_student_targets")
}

model AcademyTag {
  id        String   @id @default(cuid())
  academyId String
  academy   Academy  @relation(fields: [academyId], references: [id], onDelete: Cascade)
  label     String
  tagType   String // "subject" | "level" | "grade" | "etc"
  createdAt DateTime @default(now())

  @@unique([academyId, tagType, label])
  @@map("academy_tags")
}

// ─────────────────────────────────────────────
// IN-GANG QUIZ (인강 시험)
// ─────────────────────────────────────────────

model LectureQuiz {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])
  lectureId String  @unique
  lecture   Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  passScore    Int    @default(70)
  maxTries     Int    @default(3)
  examCond     String @default("after100") // "after100" | "anytime"
  passWatchPct Int    @default(100) // examCond='after100'일 때 요구 시청률 (50~100, 기본 100)

  questions  LectureQuestion[]
  attempts   LectureQuizAttempt[]
  retryPerms LectureRetryPermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lecture_quizzes")
}

model LectureQuestion {
  id         String                  @id @default(cuid())
  quizId     String
  quiz       LectureQuiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  orderIndex Int                     @default(0)
  text       String
  score      Int                     @default(20)
  options    LectureQuestionOption[]

  @@map("lecture_questions")
}

model LectureQuestionOption {
  id         String          @id @default(cuid())
  questionId String
  question   LectureQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  orderIndex Int             @default(0)
  text       String
  isCorrect  Boolean         @default(false)

  @@map("lecture_question_options")
}

model LectureQuizAttempt {
  id        String      @id @default(cuid())
  academyId String
  academy   Academy     @relation(fields: [academyId], references: [id])
  quizId    String
  quiz      LectureQuiz @relation(fields: [quizId], references: [id])
  studentId String
  student   Student     @relation(fields: [studentId], references: [id])
  score     Float
  isPassed  Boolean

  createdAt DateTime @default(now())

  @@map("lecture_quiz_attempts")
}

model LectureRetryPermission {
  id          String      @id @default(cuid())
  academyId   String
  academy     Academy     @relation(fields: [academyId], references: [id])
  quizId      String
  quiz        LectureQuiz @relation(fields: [quizId], references: [id])
  studentId   String
  student     Student     @relation(fields: [studentId], references: [id])
  allowedById String
  allowedBy   User        @relation(fields: [allowedById], references: [id])
  usedAt      DateTime?

  createdAt DateTime @default(now())

  @@map("lecture_retry_permissions")
}

// (학생, 강의) 단위 시청 진도 누적
// - watchedSeconds: 정상 재생으로 인정된 누적 초 (점프·탭 비활성 제외)
// - lastPositionSec: 이어보기용 마지막 위치
// - durationSec: stamp 시점의 Lecture.durationSec 복사본 (영상 교체 감지용)
// - cfVideoId: 영상 교체 감지용
// - completedAt: passWatchPct 임계 도달 시점 (WHERE NULL 가드로 1회만 set)
model LectureWatchProgress {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])
  lectureId String
  lecture   Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  watchedSeconds  Int       @default(0)
  lastPositionSec Int       @default(0)
  durationSec     Int
  cfVideoId       String
  completedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, lectureId])
  @@index([academyId, lectureId])
  @@index([academyId, studentId, updatedAt]) // 학생별 진도 조회 최적화 (통계 화면 실데이터 전환 시 활용)
  @@map("lecture_watch_progress")
}

// ─────────────────────────────────────────────
// SERIES COMPLETION & CERTIFICATES (Phase F)
// ─────────────────────────────────────────────
// (학생, 시리즈) 단위 완주 이벤트 — 자동 stamp
// - 시리즈 내 모든 강의 이수 시점에 1회 생성 (Unique [studentId, seriesId])
// - scoreSnapshot: 시리즈 내 시험 점수 집계 (평균)
// - progress/quiz/submit 라우트에서 checkAndStampSeriesCompletion helper로 trigger
model LectureSeriesCompletion {
  id        String        @id @default(cuid())
  academyId String
  academy   Academy       @relation(fields: [academyId], references: [id])
  studentId String
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  seriesId  String
  series    LectureSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  completedAt   DateTime @default(now())
  scoreSnapshot Float? // 시리즈 내 시험 평균 (시험 없는 시리즈는 null)

  certificate Certificate?

  @@unique([studentId, seriesId])
  @@index([academyId, completedAt])
  @@map("lecture_series_completions")
}

// 이수증 발급 (관리자 액션)
// - 1 LSC당 최대 1 Certificate (재발급은 cancelledAt 다음에 신규 row)
// - snapshot 필드: 발급 시점 정보 고정 (학원명·원장명 변경되어도 발급 시점 그대로)
// - PDF는 다운로드 요청 시 즉석 생성 (저장 X)
model Certificate {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  seriesCompletionId String                  @unique
  seriesCompletion   LectureSeriesCompletion @relation(fields: [seriesCompletionId], references: [id], onDelete: Cascade)

  issuedAt    DateTime  @default(now())
  issuedById  String
  issuedBy    User      @relation("CertificateIssuedBy", fields: [issuedById], references: [id])
  cancelledAt DateTime?

  // 발급 시점 snapshot (PDF에 박힘)
  academyNameSnapshot  String
  directorNameSnapshot String
  studentNameSnapshot  String
  seriesTitleSnapshot  String
  scoreSnapshot        Float?

  @@index([academyId, issuedAt])
  @@map("certificates")
}

// ─────────────────────────────────────────────
// REPORTS (학생 성적 레포트)
// ─────────────────────────────────────────────

enum ReportTemplateKind {
  PER_EXAM
  PERIODIC
}

model ReportTemplate {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  name          String
  alias         String             @default("") // 원장용 별칭 (발행된 리포트에는 노출 X)
  kind          ReportTemplateKind
  bodyMarkdown  String             @default("") // 토큰 포함된 양식 본문
  layout        Json               @default("[]") // PERIODIC 차트/표 블록 배열
  scopeFilter   Json               @default("{}") // {category1Ids?, category2Ids?, category3Ids?, subjects?}
  passThreshold Int                @default(70) // 합격 기본 70%
  periodMonths  Int? // PERIODIC 전용: 발행 시점 기준 N개월 이전부터 집계
  isActive      Boolean            @default(true)

  reports Report[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([academyId, kind])
  @@map("report_templates")
}

model Report {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  templateId String? // null = 양식 없이 발행 화면에서 직접 작성한 리포트
  template   ReportTemplate? @relation(fields: [templateId], references: [id])

  batchId String? // 같은 발행 액션으로 생성된 Report들을 묶는 식별자

  kind        ReportTemplateKind
  periodLabel String             @default("") // "2026-05" / "2026-Q1" / "2026 상반기" / "2026" / 시험명
  title       String // PWA 리스트에 보일 제목
  summary     String             @default("") // 짧은 설명 (리스트용)

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  classId   String?
  class     Class?  @relation(fields: [classId], references: [id])
  examId    String?
  exam      Exam?   @relation(fields: [examId], references: [id])

  renderedBody String @default("") // 토큰 치환 완료된 본문
  data         Json   @default("{}") // 차트 raw 데이터 + 표 데이터
  layout       Json   @default("[]") // 발행 시점에 확정된 차트 블록 (양식 layout 스냅샷, 발행 시 변경 가능)

  publishedAt DateTime  @default(now())
  publishedBy String? // 발행자 userId
  readAt      DateTime? // 학부모/학생이 처음 연 시간

  createdAt DateTime @default(now())

  @@index([academyId, studentId, publishedAt])
  @@index([studentId, readAt])
  @@index([academyId, batchId])
  @@map("reports")
}

// ─────────────────────────────────────────────
// INGANG TABLET (인강 태블릿 시청 인증)
// ─────────────────────────────────────────────

// 학생의 인강 시청 세션 (학생 인증 요청 → 강사 승인 → 시청 → 종료)
model IngangViewSession {
  id               String    @id @default(cuid())
  academyId        String
  academy          Academy   @relation(fields: [academyId], references: [id])
  studentId        String
  student          Student   @relation(fields: [studentId], references: [id])
  classId          String? // 강사가 승인 시 확정
  tabletUserId     String // 어느 태블릿 계정에서 요청했는지 (감사용)
  // PENDING | APPROVED | REJECTED | EXPIRED | ENDED
  status           String    @default("PENDING")
  requestedAt      DateTime  @default(now())
  approvedAt       DateTime?
  approvedByUserId String? // 승인한 강사/원장 userId
  endedAt          DateTime?

  @@index([academyId, status, requestedAt])
  @@index([academyId, studentId, requestedAt])
  @@map("ingang_view_sessions")
}

// 학원별 일일 인강 인증 코드 (날짜 단위)
model IngangDailyCode {
  id        String   @id @default(cuid())
  academyId String
  academy   Academy  @relation(fields: [academyId], references: [id])
  date      DateTime // 해당 날짜 (00:00 기준 UTC)
  code      String // 6자리 숫자 코드
  createdBy String // 발급/회전한 userId
  createdAt DateTime @default(now())

  @@unique([academyId, date])
  @@index([academyId, date])
  @@map("ingang_daily_codes")
}

// ─────────────────────────────────────────────
// CLASS LESSON HISTORY (수업 이력 — Comment + Clinic)
// ─────────────────────────────────────────────

// 학원이 미리 만드는 Clinic 체크 양식
// items 형식: [{ id: string, label: string, order: number }]
model ClinicTemplate {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  name        String
  description String  @default("")
  items       Json
  isActive    Boolean @default(true) // soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  results       ClinicResult[]
  makeupResults MakeupClinicResult[]

  @@index([academyId, isActive])
  @@map("clinic_templates")
}

// 강사가 수업 중 학생에게 남기는 코멘트 (학생 × 날짜 × 반 별 1행)
model LessonComment {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  classId   String
  class     Class   @relation(fields: [classId], references: [id])
  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  sessionDate DateTime // 날짜만 의미 있음 (00:00:00 UTC 정규화)
  comment     String

  authorId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, studentId, sessionDate])
  @@index([academyId, sessionDate])
  @@map("lesson_comments")
}

// Clinic 체크 결과 (학생 × 날짜 × 양식 별 1행)
// checks 형식:         [{ itemId: string, checked: boolean }]      — 양식 항목에 대한 체크 결과
// customItems 형식:    [{ id: string, label: string, checked: boolean }] — 이 세션에서 추가된 항목
// hiddenItemIds 형식:  string[]                                     — 이 세션에서 숨긴 양식 항목 ID
model ClinicResult {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  classId    String
  class      Class          @relation(fields: [classId], references: [id])
  studentId  String
  student    Student        @relation(fields: [studentId], references: [id])
  templateId String
  template   ClinicTemplate @relation(fields: [templateId], references: [id])

  sessionDate   DateTime
  checks        Json
  customItems   Json     @default("[]")
  hiddenItemIds Json     @default("[]")

  authorId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, studentId, sessionDate, templateId])
  @@index([academyId, sessionDate])
  @@map("clinic_results")
}

// 마케팅 페이지(/intro) 상담 신청 — 기존 고객이 아닌 잠재 원장 리드. 학원에 종속되지 않음(플랫폼 전역).
enum DemoRequestStatus {
  NEW // 신규 (미연락)
  CONTACTED // 연락함
  CONVERTED // 가입 전환
  CLOSED // 종료/보류
}

model DemoRequest {
  id String @id @default(cuid())

  name         String // 신청자 이름
  phone        String // 연락처
  academyName  String  @default("") // 학원명 (선택)
  studentCount String  @default("") // 학생 규모 (선택, 자유 텍스트)
  message      String  @default("") // 문의 내용 (선택)

  status DemoRequestStatus @default(NEW)
  memo   String            @default("") // 슈퍼어드민 메모

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@map("demo_requests")
}
