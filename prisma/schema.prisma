generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// TENANT / AUTH LAYER
// ─────────────────────────────────────────────

model Academy {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  loginKey  String?  @unique // 학생 로그인 ID 접두어 (3글자 대문자 영어, 예: SGR)
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── 토스페이먼츠 (학원별 결제 키) ──────────────────────
  tossClientKey    String? // 공개 키 — 평문 (브라우저 노출 OK)
  tossSecretKeyEnc String? // 비밀 키 — AES-256-GCM 암호화 저장
  tossKeyUpdatedAt DateTime? // 마지막 키 등록/변경 일시
  tossKeyUpdatedBy String? // 변경한 super_admin userId (감사 로그)

  // ── 공개 소개 페이지 (/academy/[slug]) ──────────────────
  intro          String? // 한 줄 소개
  directorName   String? // 대표자명
  businessNumber String? // 사업자등록번호
  operatingHours String? // 운영 시간 (자유 입력)
  refundPolicy   String? // 환불 정책
  showFees       Boolean @default(true) // 수강료 공개 여부
  profileEnabled Boolean @default(false) // 공개 페이지 활성화 여부
  kakaoMapUrl    String? // 카카오맵 iframe embed URL
  galleryImages  Json? // string[] — 학원 사진 URL 목록 (최대 6장)

  users                 User[]
  students              Student[]
  teachers              Teacher[]
  classes               Class[]
  bills                 Bill[]
  expenses              Expense[]
  exams                 Exam[]
  gradeRecords          GradeRecord[]
  attendance            AttendanceRecord[]
  makeupClasses         MakeupClass[]
  calendarEvents        CalendarEvent[]
  notifications         Notification[]
  consultations         ConsultationRecord[]
  announcements         Announcement[]
  textbooks             Textbook[]
  curriculumRows        CurriculumRow[]
  inquiries             PublicInquiry[]
  lectures              Lecture[]
  lectureSeries         LectureSeries[]
  customTags            AcademyTag[]
  notificationTemplates NotificationTemplate[]
  lectureQuizzes        LectureQuiz[]
  lectureQuizAttempts   LectureQuizAttempt[]
  lectureRetryPerms     LectureRetryPermission[]
  examCategories        ExamCategory[]
  assignments           Assignment[]
  reportTemplates       ReportTemplate[]
  reports               Report[]
  ingangViewSessions    IngangViewSession[]
  studentLectureNotes   StudentLectureNote[]
  ingangDailyCodes      IngangDailyCode[]

  @@map("academies")
}

enum UserRole {
  super_admin
  director
  teacher
  parent
  student
  tablet     // 인강 시청 전용 태블릿 계정
}

model User {
  id                 String    @id @default(cuid())
  email              String?   @unique // 강사/원장/슈퍼어드민
  loginId            String? // 학생(출석번호), 학부모(전화번호)
  passwordHash       String
  name               String
  role               UserRole
  isActive           Boolean   @default(true)
  tokenVersion       Int       @default(0)
  loginAttempts      Int       @default(0)
  lockedUntil        DateTime?
  mustChangePassword Boolean   @default(false)
  passwordChangedAt  DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  academyId String?
  academy   Academy? @relation(fields: [academyId], references: [id])

  teacherProfile    Teacher?                 @relation("TeacherUser")
  parentProfile     Parent?                  @relation("ParentUser")
  studentProfile    Student?                 @relation("StudentUser")
  retryPermsGiven   LectureRetryPermission[]
  pushSubscriptions PushSubscription[]

  @@unique([academyId, loginId])
  @@map("users")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  role      String?
  academyId String?
  action    String
  target    String?
  detail    Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("password_history")
}

// ─────────────────────────────────────────────
// PEOPLE
// ─────────────────────────────────────────────

enum StudentStatus {
  ACTIVE
  ON_LEAVE
  WITHDRAWN
  WAITING
}

model Student {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  name             String
  school           String        @default("")
  grade            Int           @default(1)
  phone            String?
  status           StudentStatus @default(ACTIVE)
  enrollDate       DateTime      @default(now())
  memo             String        @default("")
  avatarColor      String        @default("#4A90D9")
  attendanceNumber String        @default("")
  qrCode           String        @default("")
  birthDate        DateTime?

  userId String? @unique
  user   User?   @relation("StudentUser", fields: [userId], references: [id])

  parentLinks      StudentParent[]
  classEnrollments ClassEnrollment[]
  siblingLinks     StudentSibling[]         @relation("StudentA")
  siblingOf        StudentSibling[]         @relation("StudentB")
  attendance       AttendanceRecord[]
  gradeRecords     GradeRecord[]
  bills            Bill[]
  makeupTargets    MakeupClassTarget[]
  consultations    ConsultationRecord[]
  quizAttempts        LectureQuizAttempt[]
  retryPerms          LectureRetryPermission[]
  reports             Report[]
  ingangViewSessions  IngangViewSession[]
  lectureNotes        StudentLectureNote[]
  lectureTargets      LectureStudentTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([academyId, attendanceNumber])
  @@map("students")
}

model StudentSibling {
  studentAId String
  studentBId String
  studentA   Student @relation("StudentA", fields: [studentAId], references: [id])
  studentB   Student @relation("StudentB", fields: [studentBId], references: [id])

  @@id([studentAId, studentBId])
  @@map("student_siblings")
}

model Parent {
  id    String @id @default(cuid())
  name  String
  phone String @default("")

  userId String? @unique
  user   User?   @relation("ParentUser", fields: [userId], references: [id])

  children StudentParent[]

  @@map("parents")
}

model StudentParent {
  studentId String
  parentId  String
  student   Student @relation(fields: [studentId], references: [id])
  parent    Parent  @relation(fields: [parentId], references: [id])

  @@id([studentId, parentId])
  @@map("student_parents")
}

model Teacher {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  name        String
  subject     String  @default("")
  phone       String  @default("")
  email       String  @default("")
  avatarColor String  @default("#4A90D9")
  isActive    Boolean @default(true)
  permissions Json    @default("{\"manageStudents\":false,\"manageClasses\":false,\"manageAttendance\":true,\"manageGrades\":true,\"manageFinance\":false,\"manageNotifications\":false,\"viewReports\":true,\"admin\":false}")

  userId String? @unique
  user   User?   @relation("TeacherUser", fields: [userId], references: [id])

  classes           ClassTeacher[]
  checkedAttendance AttendanceRecord[]   @relation("CheckedBy")
  makeupClasses     MakeupClass[]
  consultations     ConsultationRecord[]
  lectures          Lecture[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teachers")
}

// ─────────────────────────────────────────────
// CLASSES
// ─────────────────────────────────────────────

model Class {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  name              String
  subject           String  @default("")
  level             String  @default("")
  color             String  @default("#4fc3a1")
  room              String  @default("")
  fee               Int     @default(0)
  feeType           String  @default("monthly") // "monthly" | "weekly" | "per-lesson"
  maxStudents       Int     @default(10)
  description       String  @default("")
  isActive          Boolean @default(true)
  curriculumPalette String  @default("green") // "red" | "orange" | "green" | "custom"

  teachers       ClassTeacher[]
  enrollments    ClassEnrollment[]
  schedules      ClassSchedule[]
  attendance     AttendanceRecord[]
  exams          Exam[]
  bills          Bill[]
  makeupClasses  MakeupClass[]
  textbooks      Textbook[]
  curriculumRows CurriculumRow[]
  announcements  Announcement[]
  calendarEvents CalendarEvent[]
  lectureTargets LectureTarget[]
  assignments    Assignment[]
  reports        Report[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("classes")
}

model ClassTeacher {
  classId   String
  teacherId String
  isPrimary Boolean @default(true)
  class     Class   @relation(fields: [classId], references: [id])
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  @@id([classId, teacherId])
  @@map("class_teachers")
}

model ClassEnrollment {
  id         String    @id @default(cuid())
  classId    String
  studentId  String
  enrolledAt DateTime  @default(now())
  droppedAt  DateTime?
  isActive   Boolean   @default(true)
  class      Class     @relation(fields: [classId], references: [id])
  student    Student   @relation(fields: [studentId], references: [id])

  @@unique([classId, studentId])
  @@map("class_enrollments")
}

model ClassSchedule {
  id        String @id @default(cuid())
  classId   String
  dayOfWeek Int
  startTime String
  endTime   String
  class     Class  @relation(fields: [classId], references: [id])

  @@map("class_schedules")
}

// ─────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EARLY_LEAVE
}

model AttendanceRecord {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  classId   String
  class     Class   @relation(fields: [classId], references: [id])

  date         DateTime
  status       AttendanceStatus
  checkInTime  String?
  checkOutTime String?
  memo         String           @default("")

  checkedById String?
  checkedBy   Teacher? @relation("CheckedBy", fields: [checkedById], references: [id])
  checkedAt   DateTime @default(now())

  @@unique([studentId, classId, date])
  @@map("attendance_records")
}

model MakeupClass {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  originalClassId String
  originalClass   Class    @relation(fields: [originalClassId], references: [id])
  originalDate    DateTime

  makeupDate DateTime
  makeupTime String   @default("")

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  reason            String  @default("")
  attendanceChecked Boolean @default(false)

  targets MakeupClassTarget[]

  createdAt DateTime @default(now())

  @@map("makeup_classes")
}

model MakeupClassTarget {
  makeupClassId String
  studentId     String
  status        AttendanceStatus?
  memo          String            @default("")
  makeupClass   MakeupClass @relation(fields: [makeupClassId], references: [id])
  student       Student     @relation(fields: [studentId], references: [id])

  @@id([makeupClassId, studentId])
  @@map("makeup_class_targets")
}

// ─────────────────────────────────────────────
// GRADES
// ─────────────────────────────────────────────

model Exam {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  name        String
  subject     String   @default("")
  date        DateTime
  totalScore  Int      @default(100)
  description String   @default("")

  // 카테고리 (1은 필수, 2/3은 옵션) — 기존 데이터 호환을 위해 모두 nullable
  category1Id String?
  category1   ExamCategory? @relation("ExamCategory1", fields: [category1Id], references: [id])
  category2Id String?
  category2   ExamCategory? @relation("ExamCategory2", fields: [category2Id], references: [id])
  category3Id String?
  category3   ExamCategory? @relation("ExamCategory3", fields: [category3Id], references: [id])

  gradeRecords GradeRecord[]
  reports      Report[]

  createdAt DateTime @default(now())

  @@map("exams")
}

model ExamCategory {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  name  String
  level Int // 1, 2, 3

  parentId String?
  parent   ExamCategory?  @relation("ExamCategoryHierarchy", fields: [parentId], references: [id])
  children ExamCategory[] @relation("ExamCategoryHierarchy")

  examsAsCategory1 Exam[] @relation("ExamCategory1")
  examsAsCategory2 Exam[] @relation("ExamCategory2")
  examsAsCategory3 Exam[] @relation("ExamCategory3")

  createdAt DateTime @default(now())

  @@index([academyId, level])
  @@index([parentId])
  @@map("exam_categories")
}

model GradeRecord {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  examId    String
  exam      Exam    @relation(fields: [examId], references: [id])
  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  score Float?
  rank  Int?
  memo  String @default("")

  @@unique([examId, studentId])
  @@map("grade_records")
}

// ─────────────────────────────────────────────
// ASSIGNMENTS
// ─────────────────────────────────────────────

model Assignment {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  date    DateTime // 과제 출제일 (반 시간표 날짜 가능)
  dueDate DateTime // 납기일
  memo    String   @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([academyId, classId])
  @@index([dueDate])
  @@map("assignments")
}

// ─────────────────────────────────────────────
// FINANCE
// ─────────────────────────────────────────────

enum BillStatus {
  PAID
  UNPAID
  PARTIAL
  CANCELLED
}

enum PaymentMethod {
  CARD
  TRANSFER
  CASH
}

model Bill {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  classId   String
  class     Class   @relation(fields: [classId], references: [id])

  month          String
  amount         Int
  paidAmount     Int            @default(0)
  status         BillStatus     @default(UNPAID)
  dueDate        DateTime
  paidDate       DateTime?
  method         PaymentMethod?
  memo           String         @default("")
  scheduledCount Int? // per-lesson: 해당 월 배정 수업 횟수
  absentCount    Int? // per-lesson: 결석 횟수
  makeupCount    Int? // per-lesson: 보강으로 복원된 횟수
  notifiedAt     DateTime? // 학부모에게 청구서 알림 발송 시각

  cancelledAt    DateTime? // 취소 시각 (CANCELLED 상태 시 기록)
  cancelReason   String? // 취소 사유
  paymentOrderId String? // 결제된 토스 PaymentOrder ID (취소 시 원본 주문 추적)

  // 재청구 링크 — 취소된 청구서에서 새로 생성된 청구서를 추적
  rebillOfId String?
  rebillOf   Bill?   @relation("BillRebill", fields: [rebillOfId], references: [id])
  rebills    Bill[]  @relation("BillRebill")

  receipts Receipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, classId, month])
  @@map("bills")
}

model Expense {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  category    String
  description String
  amount      Int
  date        DateTime
  memo        String   @default("")

  createdAt DateTime @default(now())

  @@map("expenses")
}

model Receipt {
  id     String @id @default(cuid())
  billId String
  bill   Bill   @relation(fields: [billId], references: [id])

  studentId   String
  amount      Int
  issuedDate  DateTime
  method      PaymentMethod
  memo        String        @default("")
  paidBy      String        @default("") // 수납 처리자 userId (관리자 수동 처리 시 기록, 토스 자동결제 시 빈 문자열)
  cancelledAt DateTime? // 영수증 취소 시각 (청구서 취소 시 함께 기록)

  createdAt DateTime @default(now())

  @@map("receipts")
}

// ─────────────────────────────────────────────
// COMMUNICATIONS
// ─────────────────────────────────────────────

enum NotificationType {
  ANNOUNCEMENT
  ATTENDANCE_ALERT
  PAYMENT_ALERT
  CONSULTATION_ALERT
  GENERAL
}

model Notification {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  type     NotificationType
  title    String
  content  String
  metadata Json? // { billIds: string[] } 등 추가 데이터
  sentAt   DateTime         @default(now())
  sentById String           @default("")

  recipients NotificationRecipient[]

  @@map("notifications")
}

model PaymentOrder {
  id         String   @id @default(cuid())
  academyId  String
  studentId  String
  billIds    Json // string[] — 결제 대상 청구서 ID 목록
  amount     Int
  status     String   @default("PENDING") // PENDING | PROCESSING | PAID | FAILED
  paymentKey String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("payment_orders")
}

model NotificationRecipient {
  notificationId String
  studentId      String
  readAt         DateTime?

  notification Notification @relation(fields: [notificationId], references: [id])

  @@id([notificationId, studentId])
  @@map("notification_recipients")
}

model ConsultationRecord {
  id        String  @id @default(cuid())
  academyId String
  studentId String
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  student   Student @relation(fields: [studentId], references: [id])
  academy   Academy @relation(fields: [academyId], references: [id])

  date     DateTime
  time     String   @default("")
  duration Int      @default(30)
  type     String
  topic    String
  content  String   @default("")
  followUp String   @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("consultation_records")
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
}

model Announcement {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  title       String
  content     String
  authorId    String
  status      AnnouncementStatus @default(DRAFT)
  pinned      Boolean            @default(false)
  publishedAt DateTime?

  classId String?
  class   Class?  @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

// ─────────────────────────────────────────────
// NOTIFICATION TEMPLATE (알림 템플릿)
// ─────────────────────────────────────────────

model NotificationTemplate {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  category NotificationType
  title    String
  content  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_templates")
}

// ─────────────────────────────────────────────
// PUBLIC INQUIRY (공개 페이지 상담 신청)
// ─────────────────────────────────────────────

enum InquiryStatus {
  NEW // 신규 (미확인)
  READ // 확인
  REPLIED // 답변완료
}

model PublicInquiry {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  name      String // 학생 이름
  phone     String // 연락처
  classId   String? // 관심 수업 ID (선택)
  className String? // 관심 수업명 스냅샷
  message   String  @default("") // 문의 내용

  status InquiryStatus @default(NEW)
  memo   String        @default("") // 원장 메모

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("public_inquiries")
}

// ─────────────────────────────────────────────
// CALENDAR
// ─────────────────────────────────────────────

enum CalendarEventType {
  ACADEMY_SCHEDULE
  CONSULTATION_SCHEDULE
  MAKEUP_SCHEDULE
}

// ─────────────────────────────────────────────
// CURRICULUM
// ─────────────────────────────────────────────

model Textbook {
  id           String    @id @default(cuid())
  academyId    String
  classId      String
  name         String
  publisher    String    @default("")
  unit         String    @default("권")
  totalUnits   Int       @default(1)
  currentUnit  Int       @default(1)
  price        Int       @default(0)
  isbn         String    @default("")
  purchaseDate DateTime?
  memo         String    @default("")

  academy Academy @relation(fields: [academyId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("textbooks")
}

enum CurriculumUnitType {
  MONTH
  WEEK
  SESSION
}

model CurriculumRow {
  id        String             @id @default(cuid())
  academyId String
  classId   String
  unitType  CurriculumUnitType @default(WEEK)
  startWeek Int                @default(1)
  endWeek   Int                @default(1)
  topic     String
  detail    String             @default("")
  color     String? // 사용자 직접 지정 색 (null이면 팔레트 자동 부여)
  done      Boolean            @default(false)

  academy Academy @relation(fields: [academyId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("curriculum_rows")
}

model CalendarEvent {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  title       String
  date        DateTime
  startTime   String?
  endTime     String?
  type        CalendarEventType
  isPublic    Boolean           @default(true)
  description String            @default("")
  color       String            @default("#4fc3a1")

  classId          String?
  class            Class?  @relation(fields: [classId], references: [id])
  relatedStudentId String?

  createdAt DateTime @default(now())

  @@map("calendar_events")
}

// ─────────────────────────────────────────────
// IN-GANG (인강)
// ─────────────────────────────────────────────

enum LectureStatus {
  DRAFT
  PUBLISHED
}

enum LectureTargetMode {
  CLASS      // 반 단위 지정
  INDIVIDUAL // 개별 학생 지정
  ALL        // 전체 공개
}

model Lecture {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  title       String
  description String   @default("")
  teacherId   String?
  teacher     Teacher? @relation(fields: [teacherId], references: [id])

  subjects     String[] @default([])
  levels       String[] @default([])
  targetGrades String[] @default([])
  etcTags      String[] @default([])

  seriesId      String?
  series        LectureSeries? @relation(fields: [seriesId], references: [id])
  episodeNumber Int?

  cfVideoId  String? // Cloudflare Stream video UID
  videoUrl   String?
  duration   String        @default("--:--")
  orderIndex Int           @default(0)
  status     LectureStatus @default(DRAFT)

  targetMode LectureTargetMode @default(CLASS)

  targets        LectureTarget[]
  studentTargets LectureStudentTarget[]
  quiz           LectureQuiz?
  studentNotes   StudentLectureNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lectures")
}

model LectureSeries {
  id          String        @id @default(cuid())
  academyId   String
  academy     Academy       @relation(fields: [academyId], references: [id])
  title       String
  description String        @default("")
  orderIndex  Int           @default(0)
  status      LectureStatus @default(DRAFT)
  lectures    Lecture[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("lecture_series")
}

model LectureTarget {
  lectureId String
  classId   String
  lecture   Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  class     Class   @relation(fields: [classId], references: [id])

  @@id([lectureId, classId])
  @@map("lecture_targets")
}

model LectureStudentTarget {
  lectureId String
  studentId String
  lecture   Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([lectureId, studentId])
  @@map("lecture_student_targets")
}

model AcademyTag {
  id        String   @id @default(cuid())
  academyId String
  academy   Academy  @relation(fields: [academyId], references: [id], onDelete: Cascade)
  label     String
  tagType   String // "subject" | "level" | "grade" | "etc"
  createdAt DateTime @default(now())

  @@unique([academyId, tagType, label])
  @@map("academy_tags")
}

// ─────────────────────────────────────────────
// IN-GANG QUIZ (인강 시험)
// ─────────────────────────────────────────────

model LectureQuiz {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])
  lectureId String  @unique
  lecture   Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  passScore Int    @default(70)
  maxTries  Int    @default(3)
  examCond  String @default("after100") // "after100" | "anytime"

  questions  LectureQuestion[]
  attempts   LectureQuizAttempt[]
  retryPerms LectureRetryPermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lecture_quizzes")
}

model LectureQuestion {
  id         String                  @id @default(cuid())
  quizId     String
  quiz       LectureQuiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  orderIndex Int                     @default(0)
  text       String
  score      Int                     @default(20)
  options    LectureQuestionOption[]

  @@map("lecture_questions")
}

model LectureQuestionOption {
  id         String          @id @default(cuid())
  questionId String
  question   LectureQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  orderIndex Int             @default(0)
  text       String
  isCorrect  Boolean         @default(false)

  @@map("lecture_question_options")
}

model LectureQuizAttempt {
  id        String      @id @default(cuid())
  academyId String
  academy   Academy     @relation(fields: [academyId], references: [id])
  quizId    String
  quiz      LectureQuiz @relation(fields: [quizId], references: [id])
  studentId String
  student   Student     @relation(fields: [studentId], references: [id])
  score     Float
  isPassed  Boolean

  createdAt DateTime @default(now())

  @@map("lecture_quiz_attempts")
}

model LectureRetryPermission {
  id          String      @id @default(cuid())
  academyId   String
  academy     Academy     @relation(fields: [academyId], references: [id])
  quizId      String
  quiz        LectureQuiz @relation(fields: [quizId], references: [id])
  studentId   String
  student     Student     @relation(fields: [studentId], references: [id])
  allowedById String
  allowedBy   User        @relation(fields: [allowedById], references: [id])
  usedAt      DateTime?

  createdAt DateTime @default(now())

  @@map("lecture_retry_permissions")
}

// ─────────────────────────────────────────────
// REPORTS (학생 성적 레포트)
// ─────────────────────────────────────────────

enum ReportTemplateKind {
  PER_EXAM
  PERIODIC
}

model ReportTemplate {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  name          String
  alias         String             @default("") // 원장용 별칭 (발행된 리포트에는 노출 X)
  kind          ReportTemplateKind
  bodyMarkdown  String             @default("") // 토큰 포함된 양식 본문
  layout        Json               @default("[]") // PERIODIC 차트/표 블록 배열
  scopeFilter   Json               @default("{}") // {category1Ids?, category2Ids?, category3Ids?, subjects?}
  passThreshold Int                @default(70) // 합격 기본 70%
  periodMonths  Int?               // PERIODIC 전용: 발행 시점 기준 N개월 이전부터 집계
  isActive      Boolean            @default(true)

  reports Report[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([academyId, kind])
  @@map("report_templates")
}

model Report {
  id        String  @id @default(cuid())
  academyId String
  academy   Academy @relation(fields: [academyId], references: [id])

  templateId String
  template   ReportTemplate @relation(fields: [templateId], references: [id])

  batchId   String?  // 같은 발행 액션으로 생성된 Report들을 묶는 식별자

  kind        ReportTemplateKind
  periodLabel String             @default("") // "2026-05" / "2026-Q1" / "2026 상반기" / "2026" / 시험명
  title       String // PWA 리스트에 보일 제목
  summary     String             @default("") // 짧은 설명 (리스트용)

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  classId   String?
  class     Class?  @relation(fields: [classId], references: [id])
  examId    String?
  exam      Exam?   @relation(fields: [examId], references: [id])

  renderedBody String @default("") // 토큰 치환 완료된 본문
  data         Json   @default("{}") // 차트 raw 데이터 + 표 데이터

  publishedAt DateTime  @default(now())
  publishedBy String? // 발행자 userId
  readAt      DateTime? // 학부모/학생이 처음 연 시간

  createdAt DateTime @default(now())

  @@index([academyId, studentId, publishedAt])
  @@index([studentId, readAt])
  @@index([academyId, batchId])
  @@map("reports")
}

// ─────────────────────────────────────────────
// INGANG TABLET (인강 태블릿 시청 인증)
// ─────────────────────────────────────────────

// 학생의 인강 시청 세션 (학생 인증 요청 → 강사 승인 → 시청 → 종료)
model IngangViewSession {
  id               String   @id @default(cuid())
  academyId        String
  academy          Academy  @relation(fields: [academyId], references: [id])
  studentId        String
  student          Student  @relation(fields: [studentId], references: [id])
  classId          String?  // 강사가 승인 시 확정
  tabletUserId     String   // 어느 태블릿 계정에서 요청했는지 (감사용)
  // PENDING | APPROVED | REJECTED | EXPIRED | ENDED
  status           String   @default("PENDING")
  requestedAt      DateTime @default(now())
  approvedAt       DateTime?
  approvedByUserId String?  // 승인한 강사/원장 userId
  endedAt          DateTime?

  @@index([academyId, status, requestedAt])
  @@index([academyId, studentId, requestedAt])
  @@map("ingang_view_sessions")
}

// 강사가 인강 강의별로 특정 학생에게 남긴 코멘트
model StudentLectureNote {
  id        String   @id @default(cuid())
  academyId String
  academy   Academy  @relation(fields: [academyId], references: [id])
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  lectureId String
  lecture   Lecture  @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  note      String
  authorId  String   // 작성한 teacher/director userId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, lectureId])
  @@index([academyId, lectureId])
  @@map("student_lecture_notes")
}

// 학원별 일일 인강 인증 코드 (날짜 단위)
model IngangDailyCode {
  id        String   @id @default(cuid())
  academyId String
  academy   Academy  @relation(fields: [academyId], references: [id])
  date      DateTime // 해당 날짜 (00:00 기준 UTC)
  code      String   // 6자리 숫자 코드
  createdBy String   // 발급/회전한 userId
  createdAt DateTime @default(now())

  @@unique([academyId, date])
  @@index([academyId, date])
  @@map("ingang_daily_codes")
}
